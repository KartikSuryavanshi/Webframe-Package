[flake8]
max-line-length = 88
# E203: whitespace before ':' (conflicts with Black)
# W503: line break before binary operator (conflicts with Black)
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .tox,
    .eggs,
    *.egg,
    build,
    dist,
    .venv,
    venv,
    .mypy_cache,
    .pytest_cache,
    htmlcov,
    .coverage

per-file-ignores =
    __init__.py:F401

max-complexity = 10
